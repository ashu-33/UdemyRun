{
    "folders": [
        { "path": "week1", "name": "📘 Week 1 — Python + LLM Basics" },
        { "path": "week2", "name": "📗 Week 2 — LLM Engineering" },
        { "path": "week3", "name": "📙 Week 3 — RAG + Agents" },
        { "path": "week4", "name": "📕 Week 4 — AI Tools + MCP" },
        { "path": "week5", "name": "📓 Week 5 — Advanced + Capstone" },
        { "path": ".", "name": "⚙️ Root Config" }
    ],
    "settings": {
        "python.defaultInterpreterPath": "python3",
        "python.terminal.activateEnvironment": true,
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "files.exclude": {
            "**/__pycache__": true,
            "**/.DS_Store": true,
            "**/node_modules": true
        },
        "files.associations": {
            "*.md": "markdown"
        }
    },
    "extensions": {
        "recommendations": [
            "ms-python.python",
            "ms-python.debugpy",
            "ms-toolsai.jupyter",
            "tamasfe.even-better-toml",
            "github.copilot",
            "github.copilot-chat"
        ]
    }
}
